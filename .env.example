# Copy to .env and fill in only what you have. EVERYTHING runs keyless by default
# (free data sources + local qwen3.5:9b). Keys only upgrade quality/routing.

# --- Model routing -----------------------------------------------------------
# Heavy-reasoning / synthesis / drafting / judgment tasks run on CLAUDE via the
# Claude Code CLI on your Max-plan subscription (NOT the metered Anthropic API).
# One-time setup:
#     npm install -g @anthropic-ai/claude-code     # or the native installer
#     claude login                                  # choose your Max subscription
#     claude   then  /status                        # confirm "subscription" auth
# Then these systems use Claude for the judgment layer with no per-token billing.
#
# Do NOT set ANTHROPIC_API_KEY: if present, Claude Code bills the metered API
# instead of your subscription (the router also strips it from the CLI's child env
# defensively, but leaving it unset avoids surprises elsewhere).
#
# CLAUDE_MODEL=claude-opus-4-8          # optional model override (accepts opus/sonnet too)
# CLAUDE_CLI=/path/to/claude            # optional: explicit CLI path if not on PATH
#
# If Claude is unavailable, high-judgment tasks FAIL LOUD (deterministic numbers
# only, no narrative) rather than silently dropping to qwen. To allow the local
# 9B model to stand in for the judgment layer (local testing only — quality is
# capped, not analyst-grade):
# IM_ALLOW_DEGRADED=1
# IM_DISABLE_CLAUDE=1                   # force-off the Claude route (qwen-only)

# Local model (Ollama). Defaults shown; override only if non-standard.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:9b

# --- Optional keyed data sources (keyless providers used if these are absent) ---
# All FREE keys. Each gates a keyed upgrade path; absent => the keyless/public source
# is used. Commercial tier of each is recorded in imdata/sources.py.
# BRAVE_API_KEY=...                      # upgrades web-search from DuckDuckGo to Brave
# FRED_API_KEY=...                       # macro series (public; free key). Risk-free works keyless via US Treasury.
# FMP_API_KEY=...                        # Financial Modeling Prep (free 250/day; eval license — dev only)
# ALPHAVANTAGE_API_KEY=...               # Alpha Vantage indicators (free 25/day; eval license)
# POLYGON_API_KEY=...                    # Polygon.io EOD (free; eval license)
# NEWSAPI_KEY=...                        # NewsAPI (free 100/day; content copyrighted)
# GNEWS_KEY=...                          # GNews (free tier; eval license)
# BLS_API_KEY=...                        # BLS CPI/PPI/jobs (public; free registration)
# OPENSANCTIONS_API_KEY=...              # OpenSanctions (free key; NON-COMMERCIAL license)
# REDDIT_CLIENT_ID=... REDDIT_CLIENT_SECRET=...   # Reddit/PRAW (alt-data sentiment only)

# --- Commercial-license gating -----------------------------------------------
# Set to 1 for a client-facing/resellable run: only `public`-tier (government /
# public-domain) sources are used; keyless-scrape and eval-key sources are skipped.
# Leave unset for development (all sources available). See imdata/sources.py.
# IM_COMMERCIAL_MODE=1

# --- SEC EDGAR identity (free, keyless, but SEC asks for a contact UA) --------
# SEC_USER_AGENT=Your Firm research (you@example.com)
