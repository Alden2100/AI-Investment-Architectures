# Copy to .env and fill in only what you have. EVERYTHING runs keyless by default
# (free data sources + local qwen3.5:9b). Keys only upgrade quality/routing.

# --- Model routing -----------------------------------------------------------
# If set, the router sends heavy-reasoning / synthesis / drafting / judgment tasks
# to the Claude API. If unset, those tasks fall back to local qwen3.5:9b for free.
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8          # optional override

# Local model (Ollama). Defaults shown; override only if non-standard.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:9b

# --- Optional keyed data sources (keyless providers used if these are absent) ---
# BRAVE_API_KEY=...                      # upgrades web-search from DuckDuckGo to Brave
# FRED_API_KEY=...                       # macro series (not required by any full system)

# --- SEC EDGAR identity (free, keyless, but SEC asks for a contact UA) --------
# SEC_USER_AGENT=Your Firm research (you@example.com)
